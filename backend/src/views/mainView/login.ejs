<section class="auth-shell">
    <div class="auth-card glass-panel lithic-border">
        <p class="mono-kicker">Operator Access</p>
        <h2>Login</h2>
        <p class="auth-copy">Authenticate to open your role-scoped action console.</p>

        <form action="/v1/api/auth/login" method="post" class="auth-form">
            <div class="field-stack">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" autocomplete="username" required>
            </div>

            <div class="field-stack">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" autocomplete="current-password" required>
            </div>

            <div class="auth-actions">
                <button type="submit">Login</button>
                <a href="/signup">Create new user</a>
            </div>
        </form>
    </div>
</section>
