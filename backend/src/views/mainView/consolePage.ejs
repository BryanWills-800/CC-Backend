<section class="console-shell">
    <aside class="console-sidebar glass-panel">
        <div class="brand-block">
            <div class="brand-mark">MP</div>
            <div>
                <p class="brand-title">MIDNIGHT</p>
                <p class="brand-subtitle">RBAC Command</p>
            </div>
        </div>

        <div class="context-card">
            <p class="mono-kicker">Role Context</p>
            <div class="context-row">
                <span>Role</span>
                <strong><%= role %></strong>
            </div>
            <p>Team: <%= team && team.teamName ? team.teamName : "No team selected" %></p>
            <p>Scope: Active workspace</p>
        </div>

        <nav class="console-nav" aria-label="Console sections">
            <a class="<%= page.activePage === 'overview' ? 'is-active' : '' %>" href="/overview"><span>01</span>Overview</a>
            <a class="<%= page.activePage === 'tasks' ? 'is-active' : '' %>" href="/tasks"><span>02</span>Task Matrix</a>
            <a class="<%= page.activePage === 'projects' ? 'is-active' : '' %>" href="/projects"><span>03</span>Projects</a>
            <a class="<%= page.activePage === 'permissions' ? 'is-active' : '' %>" href="/permissions"><span>04</span>Permissions</a>
            <a class="<%= page.activePage === 'members' ? 'is-active' : '' %>" href="/members"><span>05</span>Members</a>
            <a class="<%= page.activePage === 'audit' ? 'is-active' : '' %>" href="/audit"><span>06</span>Audit Logs</a>
            <a class="<%= page.activePage === 'notes' ? 'is-active' : '' %>" href="/notes"><span>07</span>Service Notes</a>
            <a class="<%= page.activePage === 'settings' ? 'is-active' : '' %>" href="/settings"><span>08</span>Settings</a>
        </nav>

        <form action="/api/auth/logout" method="post" class="sidebar-logout">
            <button type="submit">Logout</button>
        </form>
    </aside>

    <section class="console-main">
        <header class="console-header console-page-header">
            <div>
                <p class="mono-kicker"><%= page.kicker %></p>
                <h1><%= page.title %></h1>
                <p><%= page.description %></p>
            </div>
            <div class="system-status glass-panel">
                <span class="pulse-dot" aria-hidden="true"></span>
                <div>
                    <strong><%= page.statusLabel %></strong>
                    <small><%= page.statusDetail %></small>
                </div>
            </div>
        </header>

        <div class="metric-strip">
            <% page.metrics.forEach((metric) => { %>
                <article class="metric-card glass-panel lithic-border">
                    <span><%= metric.label %></span>
                    <strong><%= metric.value %></strong>
                    <p><%= metric.text %></p>
                </article>
            <% }) %>
        </div>

        <section class="console-page-grid">
            <% page.panels.forEach((panel) => { %>
                <% if (panel.href) { %>
                    <a class="console-panel glass-panel lithic-border" href="<%= panel.href %>">
                        <span class="command-index"><%= panel.tag %></span>
                        <h2><%= panel.title %></h2>
                        <p><%= panel.text %></p>
                    </a>
                <% } else { %>
                    <article class="console-panel glass-panel lithic-border">
                        <span class="command-index"><%= panel.tag %></span>
                        <h2><%= panel.title %></h2>
                        <p><%= panel.text %></p>
                    </article>
                <% } %>
            <% }) %>
        </section>
    </section>
</section>


